<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All chats</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <h1>All Chats</h1>
    <form action="/chats/new" method="get" >
        <button class="newChatButton">New Chat</button>
    </form>
    <hr>
    <% for (const chat of chats) { %>
        <div class="chat">
            <p>from:<i> <%= chat.from %></i></p>
            <div class="msg">
                <p><%= chat.message %></p>
                <form action="/chats/<%= chat._id %>/edit" method="get">
                <button>Update Message</button>
            </form>
            </div>
            <p>Recieved by:<i> <%= chat.to %></i></p>
            <hr>
            <div class="date-time">
                <p><%= chat.created_at.toString().split(" ")[4] %></p>
                <p><%= chat.created_at.toString().split(" ").slice(0,4).join(" ") %></p>
            </div>
            <form action="/chats/<%= chat.id %>?_method=DELETE" method="post">
                <button>Delete Message</button>
            </form>
        </div><br><br>
        <% } %>
</body>

</html>